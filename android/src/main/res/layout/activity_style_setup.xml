<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:fontFamily="monospace"
        android:letterSpacing="0.25"
        android:text="YOUR STYLE"
        android:textColor="@color/color_amber"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace"
        android:text="select up to 20 reference photos"
        android:textColor="@color/color_text_dim"
        android:textSize="12sp" />

    <!-- Photo grid: 4 columns × 5 rows = 20 slots -->
    <GridLayout
        android:id="@+id/glSlots"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="5" />

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:fontFamily="monospace"
        android:textColor="@color/color_amber_dim"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnUpload"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/color_amber"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:text="UPLOAD STYLE"
        android:textColor="#000000"
        android:textSize="14sp" />

</LinearLayout>
