<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"
            android:text="PHOTOMATCH"
            android:textColor="@color/color_amber"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="AI colour grading"
            android:textColor="@color/color_text_dim"
            android:textSize="13sp" />

        <!-- Style toggle row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Switch
                android:id="@+id/switchStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:fontFamily="monospace"
                android:text="USE MY STYLE"
                android:textColor="@color/color_text_dim"
                android:textSize="13sp"
                android:thumbTint="@color/color_amber"
                android:trackTint="@color/color_surface" />

            <TextView
                android:id="@+id/tvSetupStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="monospace"
                android:text="SET UP"
                android:textColor="@color/color_amber_dim"
                android:textSize="11sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/color_amber"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="CAMERA"
            android:textColor="#000000"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="GALLERY"
            android:textColor="@color/color_amber"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnBatch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="BATCH"
            android:textColor="@color/color_text_dim"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnCluster"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="CLUSTER"
            android:textColor="@color/color_text_dim"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnBurst"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="BURST"
            android:textColor="@color/color_text_dim"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnFavorites"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="FAVORITES"
            android:textColor="@color/color_amber_dim"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnFaces"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="FACES"
            android:textColor="@color/color_text_dim"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnPipeline"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/color_amber"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="PIPELINE"
            android:textColor="#000000"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnServerIp"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="SERVER IP"
            android:textColor="@color/color_text_dim"
            android:textSize="11sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
