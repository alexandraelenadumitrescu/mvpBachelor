<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:orientation="vertical">

    <!-- Before/after comparison area -->
    <FrameLayout
        android:id="@+id/flCompare"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3">

        <!-- After (full width, underneath) -->
        <ImageView
            android:id="@+id/ivAfter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- Before (clipped at divider) -->
        <ImageView
            android:id="@+id/ivBefore"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- BEFORE label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="#80000000"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingTop="3dp"
            android:paddingEnd="6dp"
            android:paddingBottom="3dp"
            android:text="BEFORE"
            android:textColor="@color/color_text"
            android:textSize="11sp" />

        <!-- AFTER label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="#80000000"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingTop="3dp"
            android:paddingEnd="6dp"
            android:paddingBottom="3dp"
            android:text="AFTER"
            android:textColor="@color/color_text"
            android:textSize="11sp" />

        <!-- Draggable divider line -->
        <View
            android:id="@+id/vDivider"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/color_amber" />

    </FrameLayout>

    <!-- Info + improvements scroll area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMatchInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/color_amber_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvImprovements"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/color_amber"
                android:textSize="13sp" />

        </LinearLayout>

    </ScrollView>

    <!-- Remove button -->
    <Button
        android:id="@+id/btnUnfavorite"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:text="REMOVE FROM FAVORITES"
        android:textColor="#FF5555"
        android:textSize="13sp" />

</LinearLayout>
