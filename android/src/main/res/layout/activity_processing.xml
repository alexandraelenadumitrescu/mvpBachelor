<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical">

    <!-- Top half: selected image preview -->
    <ImageView
        android:id="@+id/ivPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_surface"
        android:scaleType="fitCenter" />

    <!-- Blur warning banner (shown only when photo is blurry) -->
    <LinearLayout
        android:id="@+id/bannerBlur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C9A84C"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBlurWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="This photo appears blurry — results may be affected"
            android:textColor="#000000"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBlurScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/btnDismissBlur"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Dismiss"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#000000" />

    </LinearLayout>

    <!-- Bottom half: log output -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_surface"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="6dp"
            android:textColor="@color/color_amber"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:textColor="#FF5555"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/color_amber"
            android:fontFamily="monospace"
            android:text="RETRY"
            android:textColor="#000000"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
