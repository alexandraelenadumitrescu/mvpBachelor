<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row of circular face crop thumbnails -->
        <LinearLayout
            android:id="@+id/faceCropRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Face crops injected programmatically here -->

            <TextView
                android:id="@+id/tvMoreFaces"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/color_amber"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Person label -->
        <TextView
            android:id="@+id/tvPersonLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:textColor="@color/color_amber"
            android:textSize="12sp" />

        <!-- Expanded full-photo strip (GONE initially) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPersonPhotos"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
